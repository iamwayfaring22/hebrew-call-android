<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="עברית ↔ רוסית"
        android:textColor="#4ADE80"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="8dp" />

    <!-- Mode toggle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btnHe"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="📢 הוא — עבר→רוס"
            android:textSize="12sp"
            android:backgroundTint="#14532D"
            android:textColor="#86EFAC"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnRu"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="💬 אני — רוס→עבר"
            android:textSize="12sp"
            android:backgroundTint="#1E3A5F"
            android:textColor="#93C5FD"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="עצור"
        android:textColor="#888888"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <!-- Messages scroll -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/llMessages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp" />

    </ScrollView>

    <!-- Bottom buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="נקה"
            android:backgroundTint="#1A1A1A"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnStart"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="3"
            android:text="▶ התחל / START"
            android:backgroundTint="#14532D"
            android:textColor="#86EFAC"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="3"
            android:text="⏹ סטופ / STOP"
            android:backgroundTint="#7F1D1D"
            android:textColor="#FCA5A5"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
