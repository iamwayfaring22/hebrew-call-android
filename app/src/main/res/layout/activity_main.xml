<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="16dp">

    <!-- Direction label -->
    <TextView
        android:id="@+id/tvDirection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="עברית ► רוסית"
        android:textColor="#4ADE80"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <!-- Mode toggle buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnHeRu"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="📢 הוא — עבר►רוס"
            android:textSize="12sp"
            android:backgroundTint="#14532D"
            android:textColor="#86EFAC"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnRuHe"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="💬 אני — רוס►עבר"
            android:textSize="12sp"
            android:backgroundTint="#1E3A5F"
            android:textColor="#93C5FD"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="עצור"
        android:textColor="#555555"
        android:textSize="12sp"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <!-- Translations scroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0D0D0D"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvTranslations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E0E0E0"
            android:textSize="16sp"
            android:lineSpacingMultiplier="1.4"
            android:fontFamily="monospace" />
    </ScrollView>

    <!-- Buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="נקה"
            android:textColor="#888888"
            android:backgroundTint="#1A1A1A"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="3"
            android:text="התחל / START"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#86EFAC"
            android:backgroundTint="@color/start_green" />
    </LinearLayout>

</LinearLayout>
